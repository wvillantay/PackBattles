MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/packbattles?retryWrites=true&w=majority&appName=<AppName>
JWT_SECRET=replace-with-a-long-random-string

# Optional — restrict to your frontend domain in production. Defaults to * (allow all).
# CORS_ORIGINS=https://yourapp.com
# Comma-separate multiple domains: CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com

# Optional — set to false in production. Defaults to true locally.
# FLASK_DEBUG=false

# Optional — cloud platforms (Render, Railway, Fly.io) inject PORT automatically.
# Leave unset locally; defaults to 8080.
# PORT=8080

# ── Email notifications (Resend) ─────────────────────────────────────────────
# Set EMAIL_ENABLED=true in production to send shipment notification emails.
# Defaults to false — email is silently skipped when disabled or unconfigured.
# EMAIL_ENABLED=false
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com

# ── First-time setup ─────────────────────────────────────────────────────────
# After filling in MONGO_URI and JWT_SECRET above, run once to create indexes:
#
#   cd packbattles/BackEnd
#   python create_indexes.py
#
# Safe to re-run. Must be run before going live with real users.
